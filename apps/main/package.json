{
  "name": "@nop-chaos/main",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:extensions": "vite --mode extension-demo",
    "dev:mock": "vite --mode mock",
    "analyze:imports": "node ../../scripts/analyze-main-package-graph.mjs --check",
    "analyze:chunks": "node ../../scripts/analyze-main-chunk-graph.mjs --check",
    "build:analyze": "node ../../scripts/ensure-amis-file-deps-built.mjs && vite build --mode analyze && pnpm analyze:imports && pnpm analyze:chunks",
    "prebuild": "pnpm --filter @nop-chaos/plugin-demo build",
    "build": "node ../../scripts/ensure-amis-file-deps-built.mjs && tsc -p tsconfig.json --noEmit && vite build && pnpm analyze:imports && pnpm analyze:chunks",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@nop-chaos/amis-core": "workspace:*",
    "@nop-chaos/amis-react": "workspace:*",
    "@nop-chaos/core": "workspace:*",
    "@nop-chaos/plugin-bridge": "workspace:*",
    "@nop-chaos/shared": "workspace:*",
    "@nop-chaos/ui": "workspace:*",
    "@tanstack/react-query": "^5.96.1",
    "@xyflow/react": "^12.10.2",
    "amis": "file:../../../amis-react19/packages/amis",
    "amis-core": "file:../../../amis-react19/packages/amis-core",
    "amis-formula": "file:../../../amis-react19/packages/amis-formula",
    "amis-ui": "file:../../../amis-react19/packages/amis-ui",
    "i18next": "^26.0.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.4",
    "lucide-react": "^1.7.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.2",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "zustand": "^5.0.12"
  }
}
