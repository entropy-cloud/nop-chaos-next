{
  "name": "nop-frontend-template",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "turbo run dev",
    "dev:main": "turbo run dev --filter=@nop-chaos/main",
    "dev:plugin": "turbo run dev --filter=@nop-chaos/plugin-demo",
    "dev:extensions": "pnpm --filter @nop-chaos/main dev:extensions",
    "dev:mock": "pnpm --filter @nop-chaos/main dev:mock",
    "generate:extension": "node ./scripts/generate-extension.mjs",
    "build:analyze": "pnpm --filter @nop-chaos/main build:analyze",
    "analyze:main:imports": "node scripts/analyze-main-package-graph.mjs --check",
    "analyze:main:chunks": "node scripts/analyze-main-chunk-graph.mjs --check",
    "check:main:file-runtime-deps": "node scripts/check-main-external-runtime-deps.mjs --check",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "node scripts/verify-no-src-artifacts.mjs && turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "check:react19": "node scripts/check-react19-legacy-apis.mjs",
    "audit:knip": "knip --config knip.json",
    "check:duplicates": "jscpd packages/ apps/ examples/ --config .jscpd.json",
    "check:oversized-code-files": "node scripts/check-oversized-code-files.mjs",
    "check:i18n-singleton-boundaries": "node scripts/check-i18n-singleton-boundaries.mjs",
    "check:src-artifacts": "node scripts/verify-no-src-artifacts.mjs",
    "clean:dist-packages": "node scripts/clean-dist-packages.mjs",
    "clean:src-artifacts": "node scripts/clean-src-artifacts.mjs",
    "sync:amis": "bash scripts/sync-amis.sh",
    "sync:amis:build": "bash scripts/sync-amis.sh --build",
    "sync:site": "bash scripts/sync-site.sh",
    "pack:amis:deps": "node scripts/ensure-amis-file-deps-built.mjs",
    "sync:flux": "bash scripts/sync-flux-lib.sh"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@base-ui/react": "^1.3.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@rolldown/plugin-babel": "^0.2.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.96.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^6.0.1",
    "@xyflow/react": "^12.10.2",
    "autoprefixer": "^10.4.27",
    "babel-plugin-react-compiler": "1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "embla-carousel-react": "^8.1.5",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-i18next": "^6.1.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.4.0",
    "happy-dom": "^20.0.10",
    "husky": "^9.1.7",
    "i18next": "26.0.5",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.4",
    "jscpd": "^4.1.0",
    "knip": "^6.12.2",
    "lint-staged": "^16.4.0",
    "lucide-react": "^1.7.0",
    "msw": "^2.12.14",
    "postcss": "^8.5.8",
    "prettier": "^3.8.3",
    "react": "^19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.0",
    "react-i18next": "17.0.4",
    "react-json-view-lite": "^2.5.0",
    "react-resizable-panels": "^4.9.0",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1",
    "rollup": "^4.60.1",
    "rollup-plugin-esbuild": "^6.2.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "sonner": "^2.0.7",
    "systemjs": "^6.15.1",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "tailwind-merge": "^3.5.0",
    "turbo": "^2.9.6",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "input-otp": "^1.1.5",
    "vaul": "^1.1.2",
    "vite": "^8.0.3",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^4.1.2",
    "yaml": "^2.8.3",
    "zustand": "^5.0.12"
  },
  "pnpm": {
    "overrides": {
      "webworkify-webpack": "2.1.5"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix",
    "*.{json,md,css}": "prettier --write"
  }
}
