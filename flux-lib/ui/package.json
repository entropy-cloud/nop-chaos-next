{
  "name": "@nop-chaos/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./lib/utils": {
      "types": "./dist/lib/utils.d.ts",
      "default": "./dist/lib/utils.js"
    },
    "./base.css": "./dist/styles/base.css",
    "./styles.css": "./dist/styles/index.css"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "embla-carousel-react": "^8.1.5",
    "input-otp": "^1.1.5",
    "lucide-react": "^1.7.0",
    "react-day-picker": "^9.14.0",
    "react-json-view-lite": "^2.5.0",
    "react-resizable-panels": "^2.0.9",
    "recharts": "^2.10.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vaul": "^1.1.2",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/react": "^19.0.10"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && rm -rf dist/styles && cp -r src/styles dist/styles",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "lint": "echo \"Lint skipped (shadcn/ui vendored code)\""
  }
}
