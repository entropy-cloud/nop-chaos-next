{
  "name": "@nop-chaos/ui",
  "version": "0.1.0",
  "private": true,
  "sideEffects": [
    "*.css"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./chart": {
      "types": "./dist/components/ui/chart.d.ts",
      "default": "./dist/components/ui/chart.js"
    },
    "./lib/utils": {
      "types": "./dist/lib/utils.d.ts",
      "default": "./dist/lib/utils.js"
    },
    "./base.css": "./dist/styles/base.css",
    "./styles.css": "./dist/styles/index.css"
  },
  "peerDependencies": {
    "lucide-react": "^1.7.0",
    "recharts": "^3.8.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^2.0.7"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "embla-carousel-react": "^8.1.5",
    "input-otp": "^1.1.5",
    "react-day-picker": "^9.14.0",
    "react-json-view-lite": "^2.5.0",
    "react-resizable-panels": "^4.9.0",
    "tailwind-merge": "^3.5.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "lucide-react": "^1.7.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node -e \"const fs=require('fs');fs.rmSync('dist/styles',{recursive:true,force:true});fs.cpSync('src/styles','dist/styles',{recursive:true});\"",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --ignore-pattern \"**/*.d.ts\" --cache --cache-location node_modules/.cache/eslint"
  }
}
