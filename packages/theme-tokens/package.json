{
  "name": "@nop-chaos/theme-tokens",
  "version": "0.1.0",
  "private": true,
  "sideEffects": [
    "*.css"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ../../scripts/copy-build-assets.mjs src/styles.css dist/styles.css",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint \"src/**/*.ts\" --cache --cache-location node_modules/.cache/eslint"
  }
}
